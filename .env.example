# Copy this file to .env and fill in your values.
# In Vercel: add these under Project → Settings → Environment Variables.

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

ANTHROPIC_API_KEY=your_anthropic_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

CRON_SECRET=your_cron_secret_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Daily cost cap for post generation (cents). Reads the shared daily_spend
# counter (same one agent replies use). Defaults to 1000 (= $10) if missing.
POST_GENERATION_DAILY_COST_LIMIT_CENTS=1000
